<?xml version="1.0"?>
<pfsense>
  <version>19.1</version>
  <system>
    <hostname>router</hostname>
    <domain>example.test</domain>
    <timezone>America/Chicago</timezone>
  </system>
  <interfaces>
    <wan>
      <enable/>
      <if>vtnet0</if>
      <descr>WAN</descr>
      <ipaddr>dhcp</ipaddr>
    </wan>
    <lan>
      <enable/>
      <if>vtnet1</if>
      <descr>LAN</descr>
      <ipaddr>172.16.1.1</ipaddr>
      <subnet>24</subnet>
    </lan>
    <opt1>
      <enable/>
      <if>vtnet2</if>
      <descr>WAN2</descr>
      <ipaddr>dhcp</ipaddr>
    </opt1>
    <opt2>
      <if>vtnet3</if>
      <descr>WAN3</descr>
      <ipaddr>dhcp</ipaddr>
    </opt2>
  </interfaces>
  <dhcpd>
    <lan>
      <range>
        <from>172.16.1.110</from>
        <to>172.16.1.196</to>
      </range>
      <gateway>172.16.1.1</gateway>
      <dnsserver>172.16.1.222</dnsserver>
      <dnsserver>172.16.1.1</dnsserver>
      <staticmap>
        <mac>aa:bb:cc:00:00:01</mac>
        <ipaddr>172.16.1.10</ipaddr>
        <hostname>device-one</hostname>
        <descr></descr>
      </staticmap>
      <staticmap>
        <mac>aa:bb:cc:00:00:02</mac>
        <ipaddr>172.16.1.10</ipaddr>
        <hostname>device-two</hostname>
        <descr>duplicate on purpose</descr>
      </staticmap>
      <staticmap>
        <mac>aa:bb:cc:00:00:03</mac>
        <ipaddr></ipaddr>
        <hostname>no-ip-reservation</hostname>
      </staticmap>
    </lan>
  </dhcpd>
  <dyndnses>
    <dyndns>
      <type>godaddy</type>
      <username>MY_GODADDY_KEY</username>
      <password>U0VDUkVU</password>
      <host>wan</host>
      <domainname>example.test</domainname>
      <interface>wan</interface>
      <enable/>
      <descr>godaddy wan</descr>
      <id>0</id>
    </dyndns>
    <dyndns>
      <type>cloudflare</type>
      <username>user@example.test</username>
      <password>VE9LRU4=</password>
      <host>@</host>
      <domainname>example.test</domainname>
      <interface>opt1</interface>
      <enable/>
      <descr>cloudflare apex</descr>
      <id>1</id>
    </dyndns>
    <dyndns>
      <type>cloudflare</type>
      <host>admin</host>
      <domainname>gone.example</domainname>
      <interface>wan</interface>
      <enable/>
      <descr>cloudflare on dropped domain</descr>
      <id>2</id>
    </dyndns>
  </dyndnses>
  <nat>
    <rule>
      <interface>opt1</interface>
      <protocol>tcp</protocol>
      <source><any/></source>
      <destination>
        <network>opt1ip</network>
        <port>443</port>
      </destination>
      <target>172.16.1.200</target>
      <local-port>443</local-port>
      <descr>https to nginx-ingress</descr>
    </rule>
    <rule>
      <interface>opt1</interface>
      <protocol>tcp/udp</protocol>
      <source><any/></source>
      <destination>
        <network>opt1ip</network>
        <port>29810-29817</port>
      </destination>
      <target>172.16.1.240</target>
      <local-port>29810</local-port>
      <descr>omada discovery</descr>
    </rule>
    <rule>
      <interface>opt2</interface>
      <protocol>tcp</protocol>
      <source><any/></source>
      <destination>
        <network>opt2ip</network>
        <port>22</port>
      </destination>
      <target>172.16.1.99</target>
      <local-port>22</local-port>
      <descr>ssh via retired WAN3</descr>
    </rule>
    <outbound>
      <rule>
        <source><network>172.16.1.0/24</network></source>
        <interface>wan</interface>
        <destination><any/></destination>
        <descr>LAN to WAN</descr>
      </rule>
    </outbound>
  </nat>
  <dnsmasq>
    <hosts>
      <host>drop-me</host>
      <domain>gone.example</domain>
      <ip>10.0.0.1</ip>
      <descr>retired</descr>
    </hosts>
    <hosts>
      <host>keeper</host>
      <domain>local.test</domain>
      <ip>172.16.1.50</ip>
      <descr>should survive</descr>
    </hosts>
    <domainoverrides>
      <domain>retired.example</domain>
      <ip>10.0.0.9</ip>
    </domainoverrides>
  </dnsmasq>
  <filter>
    <rule>
      <type>pass</type>
      <interface>wan</interface>
      <ipprotocol>inet</ipprotocol>
      <protocol>tcp</protocol>
      <source><any/></source>
      <destination>
        <address>172.16.1.70</address>
        <port>443</port>
      </destination>
      <descr>https to server</descr>
      <tracker>1</tracker>
    </rule>
    <rule>
      <type>pass</type>
      <interface>lan</interface>
      <ipprotocol>inet</ipprotocol>
      <protocol>tcp/udp</protocol>
      <source>
        <network>lan</network>
      </source>
      <destination><any/></destination>
      <descr>LAN outbound</descr>
      <tracker>2</tracker>
    </rule>
    <rule>
      <type>block</type>
      <interface>opt2</interface>
      <ipprotocol>inet</ipprotocol>
      <source><any/></source>
      <destination><any/></destination>
      <descr>rule on retired interface</descr>
      <tracker>3</tracker>
    </rule>
    <rule>
      <type>pass</type>
      <interface>wan</interface>
      <ipprotocol>inet6</ipprotocol>
      <source><any/></source>
      <destination><any/></destination>
      <descr>ipv6 rule</descr>
      <tracker>4</tracker>
    </rule>
    <rule>
      <type>pass</type>
      <interface>lan</interface>
      <ipprotocol>inet</ipprotocol>
      <source><any/></source>
      <destination><any/></destination>
      <disabled/>
      <descr>disabled rule</descr>
      <tracker>5</tracker>
    </rule>
  </filter>
  <unbound>
    <enable/>
    <hosts>
      <host>server</host>
      <domain>local.test</domain>
      <ip>172.16.1.60</ip>
      <descr>unbound entry</descr>
    </hosts>
  </unbound>
</pfsense>
